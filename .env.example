# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Casper Blockchain Configuration
CASPER_RPC_URL=https://rpc.casper.network
CASPER_CHAIN_ID=1

# Logging
LOG_LEVEL=info

# Alert Configuration (optional)
ALERT_CHECK_INTERVAL=60 # seconds

# Signing Key Configuration (required for write operations)
# Option 1: Hex-encoded private key
CASPER_SIGNING_KEY_HEX=your_private_key_hex_here
# Option 2: PEM file path or content
CASPER_SIGNING_KEY_PEM=
# Key algorithm: ed25519 or secp256k1
CASPER_KEY_ALGORITHM=ed25519
